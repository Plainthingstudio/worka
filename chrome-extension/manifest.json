{
  "manifest_version": 3,
  "name": "Dribbble Lead Capture",
  "version": "1.0.0",
  "description": "Capture leads from Dribbble and add them to your lead management system",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://dribbble.com/*",
    "https://eqpsztxrnysaaoqvdqow.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://dribbble.com/*"],
      "js": ["content-script.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
